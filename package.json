{
  "name": "@beardcoder/lume",
  "description": "Small reactive components for existing HTML.",
  "version": "0.5.0",
  "author": "beardcoder",
  "bugs": {
    "url": "https://github.com/beardcoder/lume/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "bun-types": "^1.3.14",
    "happy-dom": "20.9.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lume.js",
      "require": "./dist/lume.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/beardcoder/lume#readme",
  "keywords": [
    "browser",
    "components",
    "html",
    "lightweight",
    "no-vdom",
    "reactive",
    "signals"
  ],
  "license": "MIT",
  "main": "./dist/lume.cjs",
  "module": "./dist/lume.js",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beardcoder/lume"
  },
  "scripts": {
    "build": "bun run scripts/build.ts && tsc -p tsconfig.build.json",
    "changeset": "changeset",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build",
    "format": "biome check --write .",
    "lint": "biome check .",
    "release": "changeset publish",
    "test": "bun test --preload ./test/setup.ts",
    "typecheck": "tsc --noEmit",
    "version": "changeset version"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts"
}
